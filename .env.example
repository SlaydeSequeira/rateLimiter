# Port the service listens on (Render sets this automatically).
PORT=3000

# Optional shared secret. When set, callers must send it as `x-api-key`.
# Leave empty to disable auth (fine for local/demo).
API_KEY=

# Optional. When set, state is kept in Redis so you can run multiple
# instances and share limits across them. When empty, an in-memory
# store is used (good for a single instance / local dev).
REDIS_URL=

# Optional path to a custom policies file. Defaults to ./config/policies.json
POLICIES_FILE=
